# Copy this file to .env and fill in your values
# .env is gitignored — never commit it

MONGODB_URI=mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/foodorder?retryWrites=true&w=majority
JWT_SECRET=some_long_random_secret_string

PORT=5000

# Frontend URL for CORS (your Vercel deployment URL)
FRONTEND_URL=https://your-app.vercel.app

# Admin seed account (created automatically on first server start)
ADMIN_EMAIL=your_admin_email@gmail.com
ADMIN_PASSWORD=your_strong_password
ADMIN_NAME=Your Name
ADMIN_PHONE=+91 00000 00000
ADMIN_ADDRESS=Your Address

# Email (optional — for contact form)
EMAIL_USER=your_gmail@gmail.com
EMAIL_PASS=your_gmail_app_password
